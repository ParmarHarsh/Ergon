# ERGON canonical environment contract. Copy to ignored .env for local tooling only.
# Labels: [API], [worker], [web-build], [migration], [validation], [secret], [optional].

# Core runtime [API, worker]
NODE_ENV=development
DEPLOYMENT_PROFILE=local
PROCESS_ROLE=api-and-worker
LOG_LEVEL=info
PORT=4000
API_HOST=127.0.0.1
WORKER_HEALTH_PORT=4001
WORKER_HEALTH_HOST=127.0.0.1
APP_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000
TRUST_PROXY=false
SESSION_COOKIE_SAME_SITE=Lax
READINESS_TIMEOUT_MS=5000

# Static web build [web-build, safe public value]
WEB_API_ORIGIN=http://localhost:4000
WEB_PORT=5173
WEB_HOST=127.0.0.1

# Authentication and abuse controls [API, worker; SESSION_SECRET is secret]
SESSION_SECRET=development-only-session-secret-change-me
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000
MFA_ENABLED=false
MFA_ENCRYPTION_KEY=
MFA_TOTP_ISSUER=Ergon

# Persistence [API, worker, migration; URLs are secrets]
# Cloud runtime: use the Supabase session-pooler URL. Migration/backup: use the direct URL.
REPOSITORY_BACKEND=file
DATABASE_URL=
DATABASE_MIGRATION_URL=
DATABASE_SSL_REQUIRED=false
DATABASE_POOL_MAX=10
FILE_REPOSITORY_PATH=data/dev-db.json

# Private evidence storage [API, worker; access credentials are secrets]
STORAGE_BACKEND=local
UPLOAD_DIR=data/private-storage
MAX_UPLOAD_MB=25
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
SIGNED_URL_EXPIRY_SECONDS=300

# Durable database job queue [API, worker]
QUEUE_BACKEND=local
QUEUE_CONCURRENCY=1
QUEUE_MAX_RETRIES=3
QUEUE_LEASE_MS=300000
QUEUE_HEARTBEAT_MS=30000
QUEUE_POLL_MS=1000
QUEUE_SHUTDOWN_TIMEOUT_MS=30000

# Malware scanning [API, worker]
MALWARE_SCAN_ENABLED=false
MALWARE_SCAN_REQUIRED_IN_PRODUCTION=false
MALWARE_SCANNER_PROVIDER=mock
MALWARE_SCAN_TIMEOUT_MS=10000
MALWARE_SCAN_FAIL_POLICY=open
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=10000

# AI evidence intelligence [worker; provider keys are secrets]
AI_ENABLED=false
AI_PROVIDER=mock
AI_MAX_FILE_TEXT_CHARS=12000
AI_MAX_OUTPUT_TOKENS=2000
AI_TIMEOUT_MS=30000
AI_CONFIDENCE_THRESHOLD=0.8
AI_REVIEW_REQUIRED_THRESHOLD=0.7
OPENAI_MODEL=
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_KEY=

# Password recovery [API; SMTP password is secret]
RECOVERY_DELIVERY_PROVIDER=disabled
RECOVERY_EXPOSE_TEST_TOKEN=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Local/demo/provisioning [local tooling; passwords are secrets]
ENABLE_DEMO_DATA=false
ADMIN_EMAIL=admin@ergon.local
ADMIN_PASSWORD=
PROVISION_ORGANIZATION_NAME=
PROVISION_ADMIN_NAME=
PROVISION_ADMIN_EMAIL=
PROVISION_ADMIN_PASSWORD=

# Explicit live validation [validation only; never enabled by normal CI]
ERGON_LIVE_CLOUD_VALIDATION=false
VALIDATION_TARGET=staging
ALLOW_PRODUCTION_VALIDATION=false
STAGING_API_ORIGIN=
TEST_DATABASE_URL=
STAGING_DATABASE_URL=
TEST_S3_BUCKET=
TEST_S3_REGION=
TEST_S3_ENDPOINT=
TEST_S3_ACCESS_KEY_ID=
TEST_S3_SECRET_ACCESS_KEY=
TEST_S3_FORCE_PATH_STYLE=true
SCANNER_VALIDATE_EICAR=false

# Backup and inventory tooling [local operations; outputs must remain outside Git]
POSTGRES_BACKUP_OUTPUT=
STORAGE_INVENTORY_OUTPUT=

# Separate controlled provider acceptance [validation only]
ERGON_LIVE_AI_ACCEPTANCE=false
ERGON_LIVE_AI_FORMAT=
ERGON_LIVE_SMTP_ACCEPTANCE=false
SMTP_ACCEPTANCE_EMAIL=

# Test/browser tooling [optional]
API_TEST_USE_S3=false
PLAYWRIGHT_CHROMIUM_EXECUTABLE=
