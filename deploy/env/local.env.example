NODE_ENV=development
DEPLOYMENT_PROFILE=local
PROCESS_ROLE=api-and-worker
LOG_LEVEL=debug
PORT=4000
API_HOST=127.0.0.1
WORKER_HEALTH_PORT=4001
WORKER_HEALTH_HOST=127.0.0.1
APP_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000
TRUST_PROXY=false
SESSION_COOKIE_SAME_SITE=Lax
WEB_API_ORIGIN=http://localhost:4000
WEB_PORT=5173
WEB_HOST=127.0.0.1
REPOSITORY_BACKEND=file
STORAGE_BACKEND=local
UPLOAD_DIR=data/private-storage
MAX_UPLOAD_MB=25
SESSION_SECRET=development-only-replace-me
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000
QUEUE_BACKEND=local
QUEUE_CONCURRENCY=1
QUEUE_MAX_RETRIES=3
QUEUE_LEASE_MS=300000
QUEUE_HEARTBEAT_MS=30000
QUEUE_POLL_MS=1000
QUEUE_SHUTDOWN_TIMEOUT_MS=30000
SIGNED_URL_EXPIRY_SECONDS=300
MALWARE_SCAN_ENABLED=true
MALWARE_SCANNER_PROVIDER=mock
MALWARE_SCAN_FAIL_POLICY=open
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=10000
AI_ENABLED=true
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=
ENABLE_DEMO_DATA=false
