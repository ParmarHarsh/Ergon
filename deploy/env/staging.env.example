NODE_ENV=production
DEPLOYMENT_PROFILE=staging
# Deploy once as api and once as worker using the same release/configuration.
PROCESS_ROLE=api
LOG_LEVEL=info
PORT=4000
API_HOST=0.0.0.0
WORKER_HEALTH_PORT=4001
WORKER_HEALTH_HOST=0.0.0.0
APP_URL=https://staging.example.com
ALLOWED_ORIGINS=https://staging.example.com
WEB_API_ORIGIN=https://staging-api.example.com
TRUST_PROXY=true
SESSION_COOKIE_SAME_SITE=None
SESSION_SECRET=replace-from-secret-manager
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000
MFA_ENABLED=false
MFA_ENCRYPTION_KEY=
MFA_TOTP_ISSUER=Ergon
RECOVERY_DELIVERY_PROVIDER=smtp
RECOVERY_EXPOSE_TEST_TOKEN=false
SMTP_HOST=replace-staging-smtp-host
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=replace-staging-sender@example.com
REPOSITORY_BACKEND=postgres
DATABASE_URL=postgresql://replace-from-secret-manager
DATABASE_MIGRATION_URL=postgresql://replace-direct-connection-from-secret-manager
DATABASE_SSL_REQUIRED=true
DATABASE_POOL_MAX=10
STORAGE_BACKEND=s3
S3_BUCKET=replace-staging-private-bucket
S3_REGION=ca-central-1
S3_ENDPOINT=https://PROJECT_REF.supabase.co/storage/v1/s3
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
SIGNED_URL_EXPIRY_SECONDS=300
MAX_UPLOAD_MB=25
READINESS_TIMEOUT_MS=5000
QUEUE_BACKEND=local
QUEUE_CONCURRENCY=1
QUEUE_MAX_RETRIES=3
QUEUE_LEASE_MS=300000
QUEUE_HEARTBEAT_MS=30000
QUEUE_POLL_MS=1000
QUEUE_SHUTDOWN_TIMEOUT_MS=30000
MALWARE_SCAN_ENABLED=true
MALWARE_SCAN_REQUIRED_IN_PRODUCTION=false
MALWARE_SCANNER_PROVIDER=clamav
MALWARE_SCAN_FAIL_POLICY=closed
MALWARE_SCAN_TIMEOUT_MS=10000
CLAMAV_HOST=replace-staging-scanner
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=10000
AI_ENABLED=false
AI_PROVIDER=openai
AI_MAX_FILE_TEXT_CHARS=12000
AI_TIMEOUT_MS=30000
AI_MAX_OUTPUT_TOKENS=2000
AI_CONFIDENCE_THRESHOLD=0.8
AI_REVIEW_REQUIRED_THRESHOLD=0.7
OPENAI_API_KEY=
OPENAI_MODEL=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
ENABLE_DEMO_DATA=false
